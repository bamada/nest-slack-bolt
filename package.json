{
  "name": "nestjs-slack-bolt",
  "version": "1.1.1",
  "description": "A NestJS module for seamless integration with Slack using the Bolt SDK",
  "author": "bamada",
  "license": "MIT",
  "homepage": "https://github.com/bamada/nest-slack-bolt#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bamada/nest-slack-bolt"
  },
  "keywords": [
    "nestjs",
    "slack",
    "bolt",
    "api",
    "integration",
    "webhook"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish --access public",
    "release": "release-it",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nestjs/common": "^10.1.3",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "^10.1.3",
    "@slack/bolt": "3.19.0",
    "reflect-metadata": "0.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-angular": "19.3.0",
    "@nestjs/cli": "10.4.0",
    "@nestjs/schematics": "10.1.2",
    "@nestjs/testing": "10.3.10",
    "@release-it/conventional-changelog": "^8.0.0",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.9",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.15.0",
    "@typescript-eslint/parser": "7.15.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "15.2.7",
    "prettier": "3.3.2",
    "release-it": "^17.0.0",
    "rimraf": "^5.0.0",
    "rxjs": "7.8.1",
    "supertest": "7.0.0",
    "ts-jest": "29.1.5",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^9.0.0 || ^10.1.3",
    "@nestjs/core": "^9.0.0 || ^10.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "^7.2.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
